PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/database
MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8
NODE_ENV=development

# Brevo REST API email provider (optional)
BREVO_API_KEY=xkeysib-your-brevo-api-key
BREVO_SENDER_EMAIL=verified-sender@example.com
BREVO_SENDER_NAME=Rancom Technologies
EMAIL_SEND_TIMEOUT_MS=15000

# Brevo SMTP provider
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-login@smtp-brevo.com
SMTP_PASS=xsmtpsib-your-brevo-smtp-key
SMTP_FROM="Rancom Technologies <verified-sender@example.com>"
